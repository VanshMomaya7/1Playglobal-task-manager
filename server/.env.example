# Server environment variables
# Copy this file to .env and fill in your values

DATABASE_URL="postgresql://postgres:postgres@localhost:5433/taskmanager"
# Use 3000 for a single API. If Docker `taskmanager_api` already binds host :3000, use 3001 for local `npm run start:dev` and point VITE at that port.
PORT=3000
NODE_ENV=development

# Google OAuth — create a "Web application" OAuth client, then add the URIs below in Google Cloud Console (Credentials → your client).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match "Authorised redirect URIs" in Google Console exactly:
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

JWT_SECRET=change-me-in-production

# Testing without Google (interns): bypass JWT and use a fixed DB user for /tasks
# Never enable on a public production API unless you understand the risk.
# AUTH_BYPASS=true
# AUTH_BYPASS_USER_ID=<uuid from User table — sign in once with Google or seed>
# AUTH_BYPASS_EMAIL=test@local

# Frontend / CORS (for deployed environments)
# Vercel example: FRONTEND_URL=https://1-playglobal-task-manager.vercel.app
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allowed origins (must include your FRONTEND_URL for cookie auth)
# Example: CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://1-playglobal-task-manager.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Optional: `npm run db:seed` attaches demo tasks to this user (Google email). Omit to seed unassigned tasks only when DB is empty.
# SEED_USER_EMAIL=
