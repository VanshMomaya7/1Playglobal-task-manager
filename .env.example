# Root environment variables for Docker Compose
# Copy this to .env and adjust as needed

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskmanager

# Constructed automatically by docker-compose.yml:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/taskmanager

# For local dev (server/.env) — use host port 5433 if Compose maps Postgres to 5433 (avoids clash with local Postgres on 5432):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/taskmanager
# PORT=3000

# Required for Docker API (docker compose reads server/.env via env_file — keep these in server/.env):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# JWT_SECRET=
